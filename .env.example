# Optional TURN relay credentials for cross-network / symmetric-NAT connectivity.
# The app ships with sensible public STUN defaults and Open Relay TURN defaults,
# so it works out of the box. For production reliability, provide your own TURN
# server (e.g. a free metered.ca account) and set these.
#
# All Vite env vars exposed to the client MUST be prefixed with VITE_.

# Comma-separated TURN urls, e.g. "turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:443"
VITE_TURN_URLS=

# TURN long-term credentials
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
